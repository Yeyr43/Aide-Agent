#!/usr/bin/env bash
# Aide Agent Launcher (Linux/macOS)
# Usage: aide   # current terminal becomes Aide TUI, daemon stays in tray
set -euo pipefail

# Resolve symlinks to find the real script location
if command -v realpath &>/dev/null; then
    _RESOLVED="$(realpath "$0")"
elif readlink -f "$0" &>/dev/null 2>&1; then
    _RESOLVED="$(readlink -f "$0")"
else
    _RESOLVED="$0"
fi
SCRIPT_DIR="$(dirname "$_RESOLVED")"
PROJECT_ROOT=""

if [[ -f "$SCRIPT_DIR/shell/tray_daemon.py" && -f "$SCRIPT_DIR/pyproject.toml" ]]; then
    PROJECT_ROOT="$SCRIPT_DIR"
elif [[ -f "$HOME/.aide/.project_path" ]]; then
    PROJECT_ROOT="$(cat "$HOME/.aide/.project_path")"
fi

if [[ -z "$PROJECT_ROOT" ]]; then
    echo "Error: Cannot find Aide project." >&2
    exit 1
fi

cd "$PROJECT_ROOT"

# 1) Start daemon in background (if not already running)
#    macOS always has a desktop. Linux: only if graphical session is available.
_START_DAEMON=false
case "$(uname -s)" in
    Darwin) _START_DAEMON=true ;;
    Linux)
        if [ -n "${DISPLAY:-}" ] || [ -n "${WAYLAND_DISPLAY:-}" ]; then
            _START_DAEMON=true
        fi
        ;;
esac

if [ "$_START_DAEMON" = true ]; then
    if ! pgrep -f "tray_daemon.py" > /dev/null 2>&1; then
        nohup uv run python shell/tray_daemon.py > /dev/null 2>&1 &
    fi
fi

# 2) Run TUI in current terminal
exec uv run python shell/main.py
