#!/usr/bin/env bash
# Aide Agent Launcher (Linux/macOS)
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT=""

# Case 1: script is in project root
if [[ -f "$SCRIPT_DIR/shell/tray_daemon.py" && -f "$SCRIPT_DIR/pyproject.toml" ]]; then
    PROJECT_ROOT="$SCRIPT_DIR"
fi

# Case 2: read from ~/.aide/.project_path
if [[ -z "$PROJECT_ROOT" && -f "$HOME/.aide/.project_path" ]]; then
    PROJECT_ROOT="$(cat "$HOME/.aide/.project_path")"
fi

if [[ -z "$PROJECT_ROOT" ]]; then
    echo "Error: Cannot find Aide project. Run install.ps1 from the project directory." >&2
    exit 1
fi

cd "$PROJECT_ROOT"
nohup uv run python shell/tray_daemon.py > /dev/null 2>&1 &
