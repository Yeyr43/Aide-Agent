#!/usr/bin/env bash
# Aide Agent Launcher (Linux/macOS)
# Usage: aide   # current terminal becomes Aide TUI, daemon stays in tray
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT=""

if [[ -f "$SCRIPT_DIR/shell/tray_daemon.py" && -f "$SCRIPT_DIR/pyproject.toml" ]]; then
    PROJECT_ROOT="$SCRIPT_DIR"
elif [[ -f "$HOME/.aide/.project_path" ]]; then
    PROJECT_ROOT="$(cat "$HOME/.aide/.project_path")"
fi

if [[ -z "$PROJECT_ROOT" ]]; then
    echo "Error: Cannot find Aide project." >&2
    exit 1
fi

cd "$PROJECT_ROOT"

# 1) Start daemon in background (if not already running)
if ! pgrep -f "tray_daemon.py" > /dev/null 2>&1; then
    nohup uv run python shell/tray_daemon.py > /dev/null 2>&1 &
fi

# 2) Run TUI in current terminal
exec uv run python shell/main.py
